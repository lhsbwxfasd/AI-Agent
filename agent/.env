# 应用配置
APP_NAME=Enterprise Agent Backend
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# LLM 配置（默认使用 DeepSeek）
OPENAI_API_KEY=""
OPENAI_BASE_URL=https://api.deepseek.com
DEFAULT_MODEL=deepseek-r1:7b
DEFAULT_TEMPERATURE=0.7
MAX_TOKENS=2000

# DeepSeek 配置
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama 配置（本地模型）
OLLAMA_BASE_URL=http://localhost:11434/v1

# 向量数据库配置
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=enterprise_knowledge

# 认证配置
SECRET_KEY=your_secret_key_change_this_in_production_please_use_strong_random_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MCP 配置
MCP_SERVER_URL=http://localhost:3000
MCP_TIMEOUT=30

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 数据库配置
# 本地开发环境使用 SQLite
DB_TYPE=sqlite
DB_SQLITE_PATH=./data/db.sqlite3

# 生产环境使用 MySQL（注释掉上面的 SQLite 配置，取消注释下面的 MySQL 配置）
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=webuser
# DB_PASSWORD=Webuser@123
# DB_DATABASE=safedb
